{
  "expo": {
    "name": "NanaBanana",
    "slug": "nanabanana-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "nanabanana",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nanabanana.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Upload product images",
        "NSPhotoLibraryUsageDescription": "Choose product images from library"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f59e0b"
      },
      "package": "com.nanabanana.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      // [
      //   "expo-notifications",
      //   {
      //     "icon": "./assets/notification-icon.png",
      //     "color": "#f59e0b",
      //     "sounds": []
      //   }
      // ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NanaBanana to access your photos to upload product images.",
          "cameraPermission": "Allow NanaBanana to use your camera to capture product images."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://192.168.31.166:4000/api"
    }
  }
}